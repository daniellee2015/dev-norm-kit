      "stage": "tooling",
      "primary": false
    }
  ],
  "provider_invocation": {
    "claude_code": "slash command files under .claude/commands/* -> /dev-clarify /dev-confirm /dev-run /dev-verify",
    "gemini_cli": "slash command files under .gemini/commands/* -> /dev-clarify /dev-confirm /dev-run /dev-verify",
    "opencode_cli": "slash command files under .opencode/commands/* -> /dev-clarify /dev-confirm /dev-run /dev-verify",
    "codex_cli": "skills under .agents/skills/dev-* (project) or ~/.codex/skills/dev-* (user)"

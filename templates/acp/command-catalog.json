      "stage": "conversation_prepare",
      "primary": true
    },
    {
      "command_id": "cmd.workflow.ready",
      "display_name": "dev:confirm",
      "purpose": "Validate readiness fields and policy before execution.",
      "run": "npm run norm:acp:ready",
      "stage": "readiness_check",
      "primary": true
    },
    {
      "command_id": "cmd.workflow.session",
      "display_name": "dev:session",
      "purpose": "Execute session_start phase route.",
      "run": "npm run norm:acp:session",
      "stage": "session_start",
      "primary": false
    },
    {
      "command_id": "cmd.workflow.run",
      "display_name": "dev:run",
      "purpose": "Execute task_start phase route.",
      "run": "npm run norm:acp:start",
      "stage": "task_start",
      "primary": true
    },
    {
      "command_id": "cmd.workflow.verify",
      "display_name": "dev:verify",
      "purpose": "Execute task_finish phase route.",
      "run": "npm run norm:acp:finish",
      "stage": "task_finish",
      "primary": true
    },
    {
      "command_id": "cmd.workflow.full-cycle",
      "display_name": "dev:full",
      "purpose": "Run session->start->finish in one command.",
      "run": "npm run norm:acp:full-cycle",
      "stage": "full_cycle",
      "primary": false
    },
    {
      "command_id": "cmd.workflow.mcp",
      "display_name": "dev:mcp",
      "purpose": "Check MCP toolkit compatibility and list active tool routes.",

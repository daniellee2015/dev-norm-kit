{
  "schema_version": "acp_active_workflow.v1",
  "provider_id": "claude_code",
  "source": "flag",
  "fallback_mode": "single_agent_human_in_the_loop",
  "role_semantics": [
    "lead",
    "worker"
  ],
  "context_management": {
    "instruction_sources": [
      ".claude/agents/",
      "CLAUDE.md"
    ],
    "delegation_strategy": "subagent_auto_delegate",
    "context_isolation_strategy": "subagent_context_boundary"
  },
  "phase_plan": [
    {
      "phase": "session_start",
      "route": "native_hook_or_wrapper",
      "command_ids": [
        "cmd.norm.registry-guard"
      ],
      "commands": [
        "npm run norm:registry:guard"
      ],
      "skill_ids": [
        "skill.session.prepare"
      ]
    },
    {
      "phase": "task_start",
      "route": "native_hook_or_wrapper",
      "command_ids": [
        "cmd.norm.lifecycle-guard"
      ],
      "commands": [
        "npm run norm:lifecycle:guard"
      ],
      "skill_ids": [
        "skill.task.clarify-or-start"
      ]
    },
    {
      "phase": "task_finish",
      "route": "native_hook_or_wrapper",
      "command_ids": [
        "cmd.norm.verify"
      ],
      "commands": [
        "npm run norm:verify"
      ],
      "skill_ids": [
        "skill.task.finish-and-report"
      ]
    }
  ]
}
